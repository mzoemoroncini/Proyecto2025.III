@page "/documentacion"
@rendermode InteractiveAuto
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Proyecto2025.III.Shared.DTO
@using Proyecto2025.III.Servicio.ServiciosHttp

@inject IHttpServicio http
@inject NavigationManager navHttp

<div class="docs-container">

    <h1 class="docs-title">
        📁 Gestión de Documentación
    </h1>

    <div class="docs-card">

        <EditForm Model="docs"
                  OnValidSubmit="Grabar"
                  FormName="CargarDocumentacionForm">

            <DataAnnotationsValidator />

            <div class="mb-4">

                <label>Descripción</label>

                <InputText class="input-custom"
                           @bind-Value="docs.Descripcion" />

                <ValidationMessage For="@(() => docs.Descripcion)" />

            </div>

            <div class="mb-4">

                <label>Archivo URL</label>

                <InputText class="input-custom"
                           @bind-Value="docs.ArchivoUrl" />

            </div>

            <div class="mb-4">

                <label>Caso</label>

                <InputSelect class="input-custom"
                             @bind-Value="docs.CasoId">

                    <option value="0">
                        -- Seleccione un Caso --
                    </option>

                    @foreach (var c in casos)
                    {
                        <option value="@c.Id">
                            @c.Id - @c.NumeroExpediente
                        </option>
                    }

                </InputSelect>

            </div>

            <div class="mb-4">

                <label>Tipo Documentación</label>

                <InputSelect class="input-custom"
                             @bind-Value="docs.TipoDocumentacionId">

                    <option value="0">
                        -- Seleccione un Tipo --
                    </option>

                    @foreach (var t in tipos)
                    {
                        <option value="@t.Id">
                            @t.Nombre
                        </option>
                    }

                </InputSelect>

            </div>

            <button class="btn-guardar"
                    type="submit"
                    disabled="@cargando">

                @(cargando ? "Guardando..." : "Guardar")

            </button>

            <button type="button"
                    class="btn-cancelar"
                    @onclick="Cancelar">

                Cancelar

            </button>

        </EditForm>

    </div>

    @if (!string.IsNullOrEmpty(Mensaje))
    {
        <div class="mensaje-box">
            @Mensaje
        </div>
    }

    <div class="docs-card">

        <h3>📄 Documentación cargada</h3>

        @if (documentos.Count == 0)
        {
            <p>No hay documentación registrada.</p>
        }
        else
        {
            <table class="tabla-documentos">

                <thead>

                    <tr>
                        <th>ID</th>
                        <th>Documento</th>
                        <th>Archivo URL</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var d in documentos)
                    {
                        <tr>

                            <td>@d.Id</td>

                            <td>@d.DatosDocumento</td>

                            <td>@d.ArchivoUrl</td>

                        </tr>
                    }

                </tbody>

            </table>
        }

    </div>

</div>

@code {

    List<CasoListadoDTO> casos = new();

    List<TipoDocumentacionListadoDTO> tipos = new();

    List<DocumentacionListadoDTO> documentos = new();

    DocumentacionDTO docs = new();

    string Mensaje = "";

    bool cargando = false;

    protected override async Task OnInitializedAsync()
    {
        await LeerCasos();

        await LeerTipos();

        await LeerDocumentacion();
    }

    private async Task LeerCasos()
    {
        var resp = await http.Get<List<CasoListadoDTO>>("api/caso/lista");

        if (!resp.Error && resp.Respuesta != null)
        {
            casos = resp.Respuesta;
        }
        else
        {
            Mensaje = resp.ObtenerError();
        }
    }

    private async Task LeerTipos()
    {
        var resp = await http.Get<List<TipoDocumentacionListadoDTO>>("api/tipo-documentacion/lista");

        if (!resp.Error && resp.Respuesta != null)
        {
            tipos = resp.Respuesta;
        }
        else
        {
            Mensaje = resp.ObtenerError();
        }
    }

    private async Task LeerDocumentacion()
    {
        var resp = await http.Get<List<DocumentacionListadoDTO>>("api/documentacion/lista");

        if (!resp.Error && resp.Respuesta != null)
        {
            documentos = resp.Respuesta;
        }
        else
        {
            documentos = new();
        }
    }

    private async Task Grabar()
    {
        Mensaje = "";

        if (docs.CasoId == 0 || docs.TipoDocumentacionId == 0)
        {
            Mensaje = "⚠️ Debe seleccionar un caso y un tipo de documentación.";
            return;
        }

        if (string.IsNullOrWhiteSpace(docs.Descripcion))
        {
            Mensaje = "⚠️ La descripción es obligatoria.";
            return;
        }

        try
        {
            cargando = true;

            var resp = await http.Post<DocumentacionDTO, int>("api/documentacion", docs);

            if (!resp.Error)
            {
                Mensaje = "✅ Documentación cargada correctamente.";

                docs = new DocumentacionDTO();

                await LeerDocumentacion();
            }
            else
            {
                Mensaje = $"❌ {resp.ObtenerError()}";
            }
        }
        finally
        {
            cargando = false;
        }
    }

    private void Cancelar()
    {
        docs = new DocumentacionDTO();

        Mensaje = "Operación cancelada.";
    }
}