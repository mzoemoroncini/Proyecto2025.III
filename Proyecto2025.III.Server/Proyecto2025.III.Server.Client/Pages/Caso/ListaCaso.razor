@page "/casos"
@rendermode InteractiveAuto

@using Microsoft.AspNetCore.Authorization
@using Proyecto2025.III.Server.Client.Shared
@using Proyecto2025.III.Shared.DTO
@using Proyecto2025.III.Servicio.ServiciosHttp

@attribute [Authorize]

@inject IHttpServicio http
@inject NavigationManager navHttp

<div class="casos-container">

    <div class="casos-header">

        <h1>⚖️ Gestión de Casos</h1>

        <a class="btn btn-nuevo"
               href="/caso/crear">
            + Nuevo Caso
        </a>

    </div>

    @if (casos == null)
    {
        <div class="loading-box">
            <p>Cargando casos...</p>
        </div>
    }
    else if (casos.Count == 0)
    {
        <div class="empty-box">
            <h3>No hay casos cargados</h3>
            <p>Comenzá registrando un nuevo expediente.</p>
        </div>
    }
    else
    {
        <div class="tabla-container">

            <table class="tabla-casos">

                <thead>
                    <tr>
                        <th>Casos</th>
                        <th>Acciones</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var caso in casos)
                    {
                        <tr>

                            <td class="datos-caso">
                                @caso.DatosCaso
                            </td>

                            <td class="acciones">

                                <a class="btn-editar"
                                       href="/caso/editar/@caso.Id">
                                    Editar
                                </a>

                                <button class="btn-eliminar"
                                        @onclick="() => Eliminar(caso)">
                                    Eliminar
                                </button>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Mensaje))
    {
        <div class="mensaje">
            @Mensaje
        </div>
    }

</div>

<Confirmacion @ref="confirmacion"
              Titulo="Eliminar Caso"
              textOk="Eliminar"
              textCancelar="Cancelar"
              onConfirm="Borrar"
              onCancel="Cancelar">

    <p>¿Seguro que desea eliminar este caso?</p>

</Confirmacion>

@code {

    List<CasoListadoDTO> casos;
    string Mensaje = "";

    Confirmacion confirmacion;

    CasoListadoDTO casoSeleccionado = null;

    protected override async Task OnInitializedAsync()
    {
        await LeerCasos();
    }

    private async Task LeerCasos()
    {
        var resp = await http.Get<List<CasoListadoDTO>>("api/caso/lista");

        if (!resp.Error)
            casos = resp.Respuesta;
        else
            Mensaje = resp.ObtenerError();
    }

    private async Task Borrar()
    {
        var resp = await http.Delete($"api/caso/{casoSeleccionado.Id}");

        if (resp.Error)
            Mensaje = resp.ObtenerError();

        casoSeleccionado = null;

        confirmacion.Ocultar();

        await LeerCasos();
    }

    private void Eliminar(CasoListadoDTO caso)
    {
        casoSeleccionado = caso;

        confirmacion.Ver();
    }

    private void Cancelar()
    {
        confirmacion.Ocultar();

        casoSeleccionado = null;
    }
}